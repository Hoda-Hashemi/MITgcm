(PID.TID 0028.0001) // Parameter file "data"
(PID.TID 0028.0001) // =======================================================
(PID.TID 0028.0001) ># ===============================================================
(PID.TID 0028.0001) ># Oceanic Williamson TC1 free-surface cosine-bell advection.
(PID.TID 0028.0001) ># One-layer, global lat-lon ocean with prescribed solid-body velocity.
(PID.TID 0028.0001) ># ===============================================================
(PID.TID 0028.0001) >
(PID.TID 0028.0001) ># Continuous equation parameters
(PID.TID 0028.0001) >&PARM01
(PID.TID 0028.0001) > omega = 7.292E-5,
(PID.TID 0028.0001) > gravity = 9.81,
(PID.TID 0028.0001) > rhoConst = 1000.,
(PID.TID 0028.0001) > buoyancyRelation = 'OCEANIC',
(PID.TID 0028.0001) > eosType = 'LINEAR',
(PID.TID 0028.0001) > tAlpha = 0.,
(PID.TID 0028.0001) > sBeta = 0.,
(PID.TID 0028.0001) >
(PID.TID 0028.0001) ># Dynamics switches
(PID.TID 0028.0001) > rigidLid = .FALSE.,
(PID.TID 0028.0001) > implicitFreeSurface = .TRUE.,
(PID.TID 0028.0001) > exactConserv = .TRUE.,
(PID.TID 0028.0001) > momStepping = .FALSE.,
(PID.TID 0028.0001) > momAdvection = .FALSE.,
(PID.TID 0028.0001) > useCoriolis = .TRUE.,
(PID.TID 0028.0001) > tempStepping = .FALSE.,
(PID.TID 0028.0001) > saltStepping = .FALSE.,
(PID.TID 0028.0001) >
(PID.TID 0028.0001) ># Viscosity / diffusion (set to zero to stay close to inviscid linear regime)
(PID.TID 0028.0001) > viscAh = 0.,
(PID.TID 0028.0001) > viscA4 = 0.,
(PID.TID 0028.0001) > diffKhT = 0.,
(PID.TID 0028.0001) > no_slip_sides = .FALSE.,
(PID.TID 0028.0001) > no_slip_bottom = .FALSE.,
(PID.TID 0028.0001) > hFacMin = 1.E-5,
(PID.TID 0028.0001) > hFacMinDr = 0.5,
(PID.TID 0028.0001) >
(PID.TID 0028.0001) ># I/O precision
(PID.TID 0028.0001) > readBinaryPrec = 32,
(PID.TID 0028.0001) > writeBinaryPrec = 64,
(PID.TID 0028.0001) > useSingleCpuIO = .TRUE.,
(PID.TID 0028.0001) >/
(PID.TID 0028.0001) >
(PID.TID 0028.0001) ># Elliptic solver parameters
(PID.TID 0028.0001) >&PARM02
(PID.TID 0028.0001) > cg2dMaxIters = 5000,
(PID.TID 0028.0001) > cg2dTargetResidual = 1.E-10,
(PID.TID 0028.0001) > cg2dPreCondFreq = 1,
(PID.TID 0028.0001) >/
(PID.TID 0028.0001) >
(PID.TID 0028.0001) ># Time stepping parameters
(PID.TID 0028.0001) >&PARM03
(PID.TID 0028.0001) > nIter0=0,
(PID.TID 0028.0001) > nTimeSteps= 17280 ,
(PID.TID 0028.0001) > abEps=0.1,
(PID.TID 0028.0001) > deltaT=60.,
(PID.TID 0028.0001) > cAdjFreq=0.,
(PID.TID 0028.0001) > pChkptFreq=0.,
(PID.TID 0028.0001) > chkptFreq=0.,
(PID.TID 0028.0001) > dumpFreq=86400.,
(PID.TID 0028.0001) > monitorSelect=1,
(PID.TID 0028.0001) > monitorFreq=86400.,
