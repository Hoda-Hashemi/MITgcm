(PID.TID 0029.0001) > viscA4 = 0.,
(PID.TID 0029.0001) > diffKhT = 0.,
(PID.TID 0029.0001) > no_slip_sides = .FALSE.,
(PID.TID 0029.0001) > no_slip_bottom = .FALSE.,
