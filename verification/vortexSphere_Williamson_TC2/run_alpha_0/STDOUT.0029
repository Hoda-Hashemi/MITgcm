(PID.TID 0029.0001) >&PARM01
(PID.TID 0029.0001) ># Planet / fluid
(PID.TID 0029.0001) > omega = 7.292E-5,
(PID.TID 0029.0001) > gravity = 9.81,
(PID.TID 0029.0001) > rhoConst = 1.,
(PID.TID 0029.0001) > buoyancyRelation = 'OCEANIC',
(PID.TID 0029.0001) > eosType = 'LINEAR',
(PID.TID 0029.0001) >
(PID.TID 0029.0001) ># Dynamics switches
(PID.TID 0029.0001) > rigidLid               = .FALSE.,
