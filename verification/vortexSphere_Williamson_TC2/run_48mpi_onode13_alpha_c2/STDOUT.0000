(PID.TID 0000.0001) > omega = 7.292E-5,
(PID.TID 0000.0001) > gravity = 9.81,
(PID.TID 0000.0001) > rhoConst = 1.,
(PID.TID 0000.0001) > buoyancyRelation = 'OCEANIC',
