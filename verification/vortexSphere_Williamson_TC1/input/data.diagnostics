# Daily diagnostics for TC1.

 &DIAGNOSTICS_LIST
  dumpAtLast = .TRUE.,
  fields(1:5,1)  = 'ETAN   ','UVEL   ','VVEL   ','PsiVEL ','PhiVEL ',
  fileName(1)    = 'tc1Diag',
  frequency(1)   = -86400.,
  timePhase(1)   = 0.,
 &

&DIAG_STATIS_PARMS
 stat_fields(1:5,1) = 'ETAN   ','UVEL   ','VVEL   ','PsiVEL ','PhiVEL ',
 stat_fName(1)      = 'tc1StDiag',
 stat_freq(1)       = -86400.,
 stat_phase(1)      = 0.,
&

