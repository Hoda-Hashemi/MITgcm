(PID.TID 0042.0001) >#  frequency(n):< 0 : write snap-shot output every |frequency| seconds
(PID.TID 0042.0001) >#               > 0 : write time-average output every frequency seconds
(PID.TID 0042.0001) >#  timePhase(n)     : write at time = timePhase + multiple of |frequency|
(PID.TID 0042.0001) >#    averagingFreq  : frequency (in s) for periodic averaging interval
(PID.TID 0042.0001) >#    averagingPhase : phase     (in s) for periodic averaging interval
(PID.TID 0042.0001) >#    repeatCycle    : number of averaging intervals in 1 cycle
(PID.TID 0042.0001) >#  levels(:,n) : list of levels to write to file (Notes: declared as REAL)
(PID.TID 0042.0001) >#                when this entry is missing, select all common levels of this list
