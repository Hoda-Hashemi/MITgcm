#!/usr/bin/env bash

set -euo pipefail

SCRIPT_DIR=$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)
ALPHA_RAD=${1:-1.5207963267948966}

cd "$SCRIPT_DIR"

search_dir="$SCRIPT_DIR"
GRID_SOURCE=""
while [[ "$search_dir" != "/" ]]; do
    candidate="$search_dir/tutorial_held_suarez_cs/input"
    if [[ -r "$candidate/grid_cs32.face001.bin" ]]; then
        GRID_SOURCE="$candidate"
        break
    fi
    search_dir=$(dirname "$search_dir")
done

if [[ -z "$GRID_SOURCE" ]]; then
    echo "ERROR: could not locate tutorial_held_suarez_cs/input." >&2
    echo "Run this case inside the MITgcm verification tree." >&2
    exit 1
fi

for face in 001 002 003 004 005 006; do
    grid_file="grid_cs32.face${face}.bin"
    source_file="$GRID_SOURCE/$grid_file"
    if [[ ! -r "$source_file" ]]; then
        echo "ERROR: missing cubed-sphere grid file: $source_file" >&2
        exit 1
    fi
    # Use real files so the prepared input directory remains movable/copyable.
    rm -f "$grid_file"
    cp "$source_file" "$grid_file"
done

export ALPHA_RAD
python3 - <<'PY'
from array import array
import math
import os
from pathlib import Path
import sys

NC = 32
NCP = NC + 1
NFACE = 6
NREC = 18

MODEL_RADIUS = 6.371e6
DAY = 86400.0
PERIOD = 12.0 * DAY
U0 = 2.0 * math.pi * MODEL_RADIUS / PERIOD
H0 = 1000.0
BELL_RADIUS = 1.0 / 3.0
BELL_LON = math.radians(270.0)
BELL_LAT = 0.0
ALPHA = float(os.environ["ALPHA_RAD"])


def read_big_endian_doubles(path):
    values = array("d")
    with path.open("rb") as handle:
        values.fromfile(handle, path.stat().st_size // values.itemsize)
    if sys.byteorder == "little":
        values.byteswap()
    return values


def write_big_endian_doubles(path, values):
    output = array("d", values)
    if sys.byteorder == "little":
        output.byteswap()
    with path.open("wb") as handle:
        output.tofile(handle)


def record(values, number):
    size = NCP * NCP
    start = (number - 1) * size
    return values[start : start + size]


def at(field, i, j):
    return field[i + NCP * j]


faces = []
total_area = 0.0
for face in range(1, NFACE + 1):
    path = Path(f"grid_cs32.face{face:03d}.bin")
    values = read_big_endian_doubles(path)
    expected = NREC * NCP * NCP
    if len(values) != expected:
        raise ValueError(f"{path}: expected {expected} values, found {len(values)}")

    fields = {
        "xc": record(values, 1),
        "yc": record(values, 2),
        "rac": record(values, 5),
        "xg": record(values, 6),
        "yg": record(values, 7),
        "dxg": record(values, 15),
        "dyg": record(values, 16),
    }
    for j in range(NC):
        for i in range(NC):
            total_area += at(fields["rac"], i, j)
    faces.append(fields)

grid_radius = math.sqrt(total_area / (4.0 * math.pi))
metric_scale = MODEL_RADIUS / grid_radius


def streamfunction(lon, lat):
    return U0 * MODEL_RADIUS * (
        math.cos(ALPHA) * math.sin(lat)
        - math.sin(ALPHA) * math.cos(lat) * math.cos(lon)
    )


tracer_faces = []
u_faces = []
v_faces = []
for fields in faces:
    psi = array("d", [0.0]) * (NCP * NCP)
    for j in range(NCP):
        for i in range(NCP):
            lon = math.radians(at(fields["xg"], i, j))
            lat = math.radians(at(fields["yg"], i, j))
            psi[i + NCP * j] = streamfunction(lon, lat)

    tracer = [[0.0 for _ in range(NC)] for _ in range(NC)]
    u = [[0.0 for _ in range(NC)] for _ in range(NC)]
    v = [[0.0 for _ in range(NC)] for _ in range(NC)]

    for j in range(NC):
        for i in range(NC):
            lon = math.radians(at(fields["xc"], i, j))
            lat = math.radians(at(fields["yc"], i, j))
            cos_distance = (
                math.sin(lat) * math.sin(BELL_LAT)
                + math.cos(lat) * math.cos(BELL_LAT)
                * math.cos(lon - BELL_LON)
            )
            distance = math.acos(max(-1.0, min(1.0, cos_distance)))
            if distance < BELL_RADIUS:
                tracer[j][i] = 0.5 * H0 * (
                    1.0 + math.cos(math.pi * distance / BELL_RADIUS)
                )

            dyg = at(fields["dyg"], i, j) * metric_scale
            dxg = at(fields["dxg"], i, j) * metric_scale
            u[j][i] = (
                psi[i + NCP * (j + 1)] - psi[i + NCP * j]
            ) / dyg
            v[j][i] = (
                psi[i + NCP * j] - psi[(i + 1) + NCP * j]
            ) / dxg

    tracer_faces.append(tracer)
    u_faces.append(u)
    v_faces.append(v)


def compact_values(face_fields):
    # Match the advect_cs compact ordering: (i, face, j), i fastest.
    values = []
    for j in range(NC):
        for face in range(NFACE):
            for i in range(NC):
                values.append(face_fields[face][j][i])
    return values


tracer_values = compact_values(tracer_faces)
u_values = compact_values(u_faces)
v_values = compact_values(v_faces)

write_big_endian_doubles(Path("S_init.bin"), tracer_values)
write_big_endian_doubles(Path("U_init.bin"), u_values)
write_big_endian_doubles(Path("V_init.bin"), v_values)

print(f"cs-32 grid radius: {grid_radius:.3f} m")
print(f"model radius:      {MODEL_RADIUS:.3f} m")
print(f"alpha:             {ALPHA:.15f} rad")
print(f"solid-body speed:  {U0:.9f} m/s")
print(
    "tracer range:     "
    f"{min(tracer_values):.6e} .. {max(tracer_values):.6e}"
)
print(f"U range:          {min(u_values):.6e} .. {max(u_values):.6e}")
print(f"V range:          {min(v_values):.6e} .. {max(v_values):.6e}")
PY

echo "Prepared cs-32 TC1 inputs in $SCRIPT_DIR"
echo "Use './prepare_run 1.5707963267948966' for exact pole crossing."
