(PID.TID 0000.0001) ># ===============================================================
(PID.TID 0000.0001) ># Hashemi Primitive-Equation Reference Case (MITgcm native solve)
(PID.TID 0000.0001) ># One-layer, global lat-lon, linearized barotropic dynamics.
(PID.TID 0000.0001) ># ===============================================================
(PID.TID 0000.0001) >
(PID.TID 0000.0001) ># Continuous equation parameters
(PID.TID 0000.0001) >&PARM01
(PID.TID 0000.0001) ># Planet / fluid
(PID.TID 0000.0001) > omega = 7.292E-5,
(PID.TID 0000.0001) > gravity = 9.81,
(PID.TID 0000.0001) > rhoConst = 1000.,
(PID.TID 0000.0001) > buoyancyRelation = 'OCEANIC',
(PID.TID 0000.0001) > eosType = 'LINEAR',
(PID.TID 0000.0001) >
(PID.TID 0000.0001) ># Dynamics switches
(PID.TID 0000.0001) > rigidLid = .FALSE.,
(PID.TID 0000.0001) > implicitFreeSurface = .TRUE.,
